{
  "name": "ejs-colorizer",
  "displayName": "EJS Colorizer",
  "description": "Complete EJS language support for VS Code — semantic token highlighting, include navigation, folding, completions, hover, and diagnostics.",
  "version": "2.2.1",
  "publisher": "connorontheweb",
  "license": "MIT",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/connorontheweb/ejs-colorizer"
  },
  "keywords": ["ejs", "template", "syntax highlighting", "html", "javascript", "semantic tokens"],
  "icon": "images/ejs-colorizer.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run build:prod && vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "vscode-html-languageservice": "^5.3.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "ejs",
        "aliases": ["EJS", "ejs"],
        "extensions": [".ejs"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ejs",
        "scopeName": "text.html.ejs",
        "path": "./syntaxes/ejs.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "text.html.basic": "html"
        }
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "ejsDelimiter",
        "superType": "keyword",
        "description": "EJS template tag delimiter (<%=, <%, -%>, etc.)"
      },
      {
        "id": "htmlTagName",
        "description": "HTML element tag name"
      },
      {
        "id": "htmlAttributeName",
        "description": "HTML element attribute name"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "ejs",
        "scopes": {
          "ejsDelimiter": ["punctuation.section.embedded"],
          "htmlTagName": ["entity.name.tag"],
          "htmlAttributeName": ["entity.other.attribute-name"]
        }
      }
    ],
    "configurationDefaults": {
      "[ejs]": {
        "editor.semanticHighlighting.enabled": true
      },
      "emmet.includeLanguages": {
        "ejs": "html"
      }
    }
  }
}
