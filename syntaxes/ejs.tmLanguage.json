{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "EJS",
	"scopeName": "text.html.ejs",
	"patterns": [
		{ "include": "#ejs-comment" },
		{ "include": "#ejs-output-escaped" },
		{ "include": "#ejs-output-unescaped" },
		{ "include": "#ejs-whitespace-slurp" },
		{ "include": "#ejs-scriptlet" },
		{ "include": "#style-block" },
		{ "include": "#script-block" },
		{ "include": "#html-content" }
	],
	"repository": {
		"ejs-comment": {
			"name": "comment.block.ejs",
			"begin": "<%#",
			"end": "(?:-|_)?%>",
			"beginCaptures": {
				"0": { "name": "punctuation.section.embedded.begin.ejs" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.embedded.end.ejs" }
			}
		},
		"ejs-output-escaped": {
			"name": "meta.embedded.block.javascript",
			"begin": "<%=",
			"end": "(?:-|_)?%>",
			"beginCaptures": {
				"0": { "name": "punctuation.section.embedded.begin.ejs" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.embedded.end.ejs" }
			}
		},
		"ejs-output-unescaped": {
			"name": "meta.embedded.block.javascript",
			"begin": "<%-",
			"end": "(?:-|_)?%>",
			"beginCaptures": {
				"0": { "name": "punctuation.section.embedded.begin.ejs" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.embedded.end.ejs" }
			}
		},
		"ejs-whitespace-slurp": {
			"name": "meta.embedded.block.javascript",
			"begin": "<%_",
			"end": "(?:-|_)?%>",
			"beginCaptures": {
				"0": { "name": "punctuation.section.embedded.begin.ejs" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.embedded.end.ejs" }
			}
		},
		"html-content": {
			"name": "meta.html-content.ejs",
			"patterns": [
				{ "include": "text.html.basic" }
			]
		},
		"script-block": {
			"begin": "(?i)(<)(script)(?=\\s|/?>)",
			"end": "(?i)(<\\/)(script)(\\s*>)",
			"name": "meta.embedded.block.html",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.tag.html" },
				"2": { "name": "entity.name.tag.html" }
			},
			"endCaptures": {
				"1": { "name": "punctuation.definition.tag.html" },
				"2": { "name": "entity.name.tag.html" },
				"3": { "name": "punctuation.definition.tag.html" }
			},
			"patterns": [
				{
					"begin": "\\G",
					"end": "(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.html" }
					}
				},
				{
					"begin": "(?!\\G)",
					"end": "(?=(?i)<\\/script)",
					"name": "source.js",
					"patterns": [
						{ "include": "#ejs-comment" },
						{ "include": "#ejs-output-escaped" },
						{ "include": "#ejs-output-unescaped" },
						{ "include": "#ejs-whitespace-slurp" },
						{ "include": "#ejs-scriptlet" },
						{ "include": "source.js" }
					]
				}
			]
		},
		"style-block": {
			"begin": "(?i)(<)(style)(?=\\s|/?>)",
			"end": "(?i)(<\\/)(style)(\\s*>)",
			"name": "meta.embedded.block.html",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.tag.html" },
				"2": { "name": "entity.name.tag.html" }
			},
			"endCaptures": {
				"1": { "name": "punctuation.definition.tag.html" },
				"2": { "name": "entity.name.tag.html" },
				"3": { "name": "punctuation.definition.tag.html" }
			},
			"patterns": [
				{
					"begin": "\\G",
					"end": "(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.html" }
					}
				},
				{
					"begin": "(?!\\G)",
					"end": "(?=(?i)<\\/style)",
					"name": "source.css",
					"patterns": [
						{ "include": "#ejs-comment" },
						{ "include": "#ejs-output-escaped" },
						{ "include": "#ejs-output-unescaped" },
						{ "include": "#ejs-whitespace-slurp" },
						{ "include": "#ejs-scriptlet" },
						{ "include": "source.css" }
					]
				}
			]
		},
		"ejs-scriptlet": {
			"name": "meta.embedded.block.javascript",
			"begin": "<%(?![=\\-_#])",
			"end": "(?:-|_)?%>",
			"beginCaptures": {
				"0": { "name": "punctuation.section.embedded.begin.ejs" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.section.embedded.end.ejs" }
			}
		}
	}
}