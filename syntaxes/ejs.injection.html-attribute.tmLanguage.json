{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "EJS Injection (HTML Attribute Values)",
	"scopeName": "ejs.injection.html-attribute",
	"injectionSelector": "L:text.html.ejs string.quoted.double.html, L:text.html.ejs string.quoted.single.html",
	"patterns": [
		{ "include": "text.html.ejs#ejs-comment" },
		{ "include": "text.html.ejs#ejs-output-escaped" },
		{ "include": "text.html.ejs#ejs-output-unescaped" },
		{ "include": "text.html.ejs#ejs-whitespace-slurp" },
		{ "include": "text.html.ejs#ejs-scriptlet" }
	]
}
